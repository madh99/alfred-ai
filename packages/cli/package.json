  "repository": {
    "type": "git",
    "url": "https://github.com/madh99/alfred-ai.git"
  },
  "homepage": "https://github.com/madh99/alfred-ai#readme",
  "bugs": {
    "url": "https://github.com/madh99/alfred-ai/issues"
  },
  "dependencies": {
