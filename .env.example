# Alfred Environment Variables
# Copy this to .env and fill in your values.

# === Messaging Platforms ===

# Telegram Bot Token (from @BotFather)
ALFRED_TELEGRAM_TOKEN=

# Discord Bot Token
ALFRED_DISCORD_TOKEN=

# Matrix Homeserver
ALFRED_MATRIX_HOMESERVER_URL=https://matrix.org
ALFRED_MATRIX_ACCESS_TOKEN=
ALFRED_MATRIX_USER_ID=

# Signal (signal-cli-rest-api)
ALFRED_SIGNAL_API_URL=http://localhost:8080
ALFRED_SIGNAL_PHONE_NUMBER=

# === LLM ===

# Anthropic API Key
ALFRED_ANTHROPIC_API_KEY=

# LLM Model (optional, default: claude-sonnet-4-20250514)
# ALFRED_LLM_MODEL=claude-sonnet-4-20250514

# === Storage & Logging ===

# Storage path (optional, default: ./data/alfred.db)
# ALFRED_STORAGE_PATH=./data/alfred.db

# Log level (optional, default: info)
# ALFRED_LOG_LEVEL=info

# === Security ===

# Owner user ID for elevated permissions
# ALFRED_OWNER_USER_ID=
